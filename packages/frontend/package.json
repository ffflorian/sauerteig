{
  "author": "Florian Imdahl <git@ffflorian.de>",
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ]
  },
  "dependencies": {
    "date-fns": "4.4.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-swipeable": "7.0.2"
  },
  "devDependencies": {
    "@ffflorian/prettier-config": "1.0.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "~26",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "happy-dom": "20.10.6",
    "jsdom": "29.1.1",
    "oxlint": "1.72.0",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vite-plugin-eslint": "1.8.1",
    "vitest": "4.1.10"
  },
  "name": "sauerteig-frontend",
  "prettier": "@ffflorian/prettier-config",
  "private": true,
  "scripts": {
    "build": "tsc && vite build",
    "clean": "rm -rf dist",
    "dev": "yarn start",
    "dist": "yarn clean && yarn build",
    "fix": "yarn fix:ts && yarn fix:other",
    "fix:other": "yarn prettier --write",
    "fix:ts": "yarn lint:ts:oxlint --fix && yarn lint:ts:eslint --fix",
    "lint": "yarn lint:other && yarn lint:ts",
    "lint:other": "yarn prettier --list-different",
    "lint:ts": "yarn lint:ts:oxlint && yarn lint:ts:eslint",
    "lint:ts:eslint": "eslint .",
    "lint:ts:oxlint": "oxlint --ignore-path .gitignore .",
    "prettier": "prettier --ignore-path ../../.prettierignore .",
    "start": "vite --open",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "version": "1.0.1"
}
