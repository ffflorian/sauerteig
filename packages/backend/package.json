{
  "dependencies": {
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/throttler": "6.5.0",
    "helmet": "8.2.0",
    "mongoose": "9.7.4",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "web-push": "3.6.7"
  },
  "devDependencies": {
    "@ffflorian/eslint-config": "1.0.4",
    "@ffflorian/prettier-config": "1.0.0",
    "@types/node": "~26",
    "@types/web-push": "3.6.4",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "oxlint": "1.73.0",
    "prettier": "3.9.5",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  },
  "files": [
    "dist"
  ],
  "name": "sauerteig-backend",
  "prettier": "@ffflorian/prettier-config",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "IS_LOCAL=true yarn start",
    "dist": "yarn clean && yarn build",
    "fix": "yarn fix:ts && yarn fix:other",
    "fix:other": "yarn prettier --write",
    "fix:ts": "yarn lint:ts:oxlint --fix && yarn lint:ts:eslint --fix",
    "lint": "yarn lint:other && yarn lint:ts",
    "lint:other": "yarn prettier --list-different",
    "lint:ts": "yarn lint:ts:oxlint && yarn lint:ts:eslint",
    "lint:ts:eslint": "eslint .",
    "lint:ts:oxlint": "oxlint --ignore-path .gitignore .",
    "prettier": "prettier --ignore-path ../../.prettierignore .",
    "start": "tsx src/main.ts",
    "start:prod": "node dist/main.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "version": "1.0.0"
}
