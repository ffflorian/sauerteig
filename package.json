{
  "author": "Florian Imdahl <git@ffflorian.de>",
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ]
  },
  "dependencies": {
    "date-fns": "4.1.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-swipeable": "7.0.2"
  },
  "devDependencies": {
    "@evilmartians/lefthook": "2.1.5",
    "@ffflorian/eslint-config-react": "0.2.2",
    "@ffflorian/prettier-config": "0.8.2",
    "@types/node": "~24",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "oxlint": "1.57.0",
    "prettier": "3.8.2",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vite-plugin-eslint": "1.8.1"
  },
  "engines": {
    "node": ">= 14.10"
  },
  "license": "GPL-3.0",
  "name": "sauerteig",
  "prettier": "@ffflorian/prettier-config",
  "private": true,
  "resolutions": {
    "strip-ansi": "^6"
  },
  "scripts": {
    "build": "tsc && vite build",
    "clear": "rm -rf dist",
    "dev": "yarn start",
    "dist": "yarn clear && yarn build",
    "fix": "yarn fix:ts && yarn fix:other",
    "fix:other": "yarn prettier --write \"src/*.{json,md,js,ts,jsx,tsx,yml}\"",
    "fix:ts": "yarn lint:ts:oxlint --fix && yarn lint:ts:eslint --fix",
    "lint": "yarn lint:other && yarn lint:ts",
    "lint:other": "yarn prettier --list-different",
    "lint:ts": "yarn lint:ts:oxlint && yarn lint:ts:eslint",
    "lint:ts:eslint": "eslint .",
    "lint:ts:oxlint": "oxlint --ignore-path .gitignore .",
    "prettier": "prettier \"*.{json,md,yml}\"",
    "start": "vite --open",
    "test": "exit 0"
  },
  "version": "1.6.0",
  "packageManager": "yarn@4.14.1"
}
